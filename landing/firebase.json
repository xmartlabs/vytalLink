{
  "hosting": {
    "predeploy": [
      "./scripts/build-css.sh",
      "./scripts/build-llms.sh"
    ],
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/node_modules/**",
      "**/.DS_Store"
    ],
    "headers": [
      {
        "source": "/llms*.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/**/*.md",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/.well-known/assetlinks.json",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "/apple-app-site-association",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json; charset=utf-8"
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/about",
        "destination": "/about.html",
        "type": 301
      },
      {
        "source": "/contact",
        "destination": "/contact.html",
        "type": 301
      },
      {
        "source": "/terms",
        "destination": "/terms.html",
        "type": 301
      },
      {
        "source": "/privacy",
        "destination": "/privacy.html",
        "type": 301
      },
      {
        "source": "/mcp-setup",
        "destination": "/mcp-setup.html",
        "type": 301
      },
      {
        "source": "/demo",
        "destination": "/demo.html",
        "type": 301
      },
      {
        "source": "/developers",
        "destination": "/developers.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/app",
        "destination": "/app.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
